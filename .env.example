# ─── Albion Market Bot — Variables de entorno ───────────────────────────────
# Copia este archivo como .env y rellena los valores

# Token de tu bot (obtenido en https://discord.com/developers/applications)
DISCORD_TOKEN=TU_TOKEN_AQUI

# Application ID de tu bot (en la página de tu aplicación > General Information)
CLIENT_ID=TU_CLIENT_ID_AQUI
